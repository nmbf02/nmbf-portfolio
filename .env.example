# EmailJS - Configuración para el formulario de contacto
# Obtén estas credenciales en https://www.emailjs.com/
# La Public Key está diseñada para uso client-side; Service y Template son públicos.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=tu_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=tu_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=tu_public_key
